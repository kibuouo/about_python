import requests
from bs4 import BeautifulSoup
import csv
import pandas as pd
def get_html(url):
    response=requests.get(url)
    return response.text

def parser(html):
    soup=BeautifulSoup(html,"html.parser")
    movie_list=[]
    items=soup.find_all("div",class_="el-card__body")
    for item in items:
        title_tag=item.find("h2")
        score_tag=item.find("p",class_="score")
        movie={
            "title":title_tag.text.strip(),
            "score":score_tag.text.strip()
        }
        movie_list.append(movie)
    return movie_list

def savetocsv(movie_list,filename):
    with open(filename,"w",encoding="utf-8-sig",newline="") as f:
        writer=csv.DictWriter(f,fieldnames=["title","score"])
        writer.writeheader()
        writer.writerows(movie_list)
if __name__=="__main__":
    datas=[]
    for page in range(1,11):
        url=f"https://ssr1.scrape.center/page/{page}"
        html=get_html(url)
        data=parser(html)
        datas.extend(data)
    savetocsv(datas,"movielist.csv")
    df=pd.read_csv("movielist.csv")
    print(df)